/* pages/index/index.wxss - 莫兰迪色系 */
page {
  background: #f5f5f0;
  height: 100%;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 标题区 */
.header {
  margin-bottom: 60rpx;
}

.app-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #3d3d3d;
}

.app-subtitle {
  font-size: 32rpx;
  color: #8a8a8a;
  margin-left: 16rpx;
}

/* 八字穿搭区 */
.bazi-section {
  margin-bottom: 40rpx;
}

.section-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.recommendation-card {
  background: #e8ebe5;
  border-radius: 24rpx;
  padding: 40rpx;
}

.vibe {
  font-size: 40rpx;
  font-weight: 600;
  color: #5a5a5a;
  margin-bottom: 16rpx;
}

.element {
  font-size: 28rpx;
  color: #7d8a7d;
  margin-bottom: 16rpx;
}

.colors {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.color-label {
  color: #999;
}

.color-list {
  color: #5a5a5a;
}

.reason {
  font-size: 24rpx;
  color: #888;
  font-style: italic;
}

/* 空状态卡片 */
.empty-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 智能选衣入口 */
.menu-section {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.menu-item {
  flex: 1;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3d3d3d;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

/* 设置图标 */
.settings-icon {
  position: fixed;
  top: 30rpx;
  right: 30rpx;
  font-size: 48rpx;
}