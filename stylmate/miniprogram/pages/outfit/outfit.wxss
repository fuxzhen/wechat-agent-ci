/* pages/outfit/outfit.wxss - 莫兰迪色系 */
page {
  background: #f5f5f0;
  height: 100%;
}

.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #3d3d3d;
}

/* 场合选择 */
.occasion-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.occasion-grid {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.occasion-item {
  padding: 24rpx 40rpx;
  background: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.occasion-item.active {
  background: #7d8a7d;
  color: #ffffff;
}

/* 八字提示 */
.bazi-tip {
  padding: 20rpx 30rpx;
  background: #e8ebe5;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #7d8a7d;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 生成按钮 */
.generate-btn {
  width: 100%;
  height: 96rpx;
  background: #7d8a7d;
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 40rpx;
}

.generate-btn[disabled] {
  background: #ccc;
}

/* 穿搭结果 */
.outfits-result {
  margin-top: 40rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3d3d3d;
  margin-bottom: 30rpx;
}

.outfit-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.outfit-items {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.outfit-image {
  width: 160rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.outfit-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.outfit-score {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.score-label {
  font-size: 24rpx;
  color: #999;
}

.score-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #7d8a7d;
}

.outfit-reason {
  font-size: 26rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.go-closet-btn {
  margin-top: 30rpx;
  padding: 20rpx 60rpx;
  background: #7d8a7d;
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
}